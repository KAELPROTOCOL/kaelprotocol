# Kael closed developer testnet example.
# Safe defaults for two local Anvil chains only. Do not use real keys or real funds.

KAEL_RPC_A=http://127.0.0.1:8545
KAEL_RPC_B=http://127.0.0.1:8546
KAEL_CHAIN_A=31337
KAEL_CHAIN_B=31338

# Filled automatically by scripts/run_closed_testnet_local.sh after deploying HashedTimelock.
KAEL_HTLC_A=0x0000000000000000000000000000000000000000
KAEL_HTLC_B=0x0000000000000000000000000000000000000000

# Default Anvil test keys. These are public test fixtures, not secrets.
KAEL_SIGNER_KEY_A=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
KAEL_SIGNER_KEY_B=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

KAEL_AMOUNT_A_WEI=1000000000000000
KAEL_AMOUNT_B_WEI=1000000000000000
KAEL_CLOSED_TESTNET_MIN_CONFIRMATIONS=1
KAEL_CLOSED_TESTNET_MIN_BALANCE_WEI=10000000000000000
KAEL_CLOSED_TESTNET_MAX_AMOUNT_WEI=10000000000000000
KAEL_TAKER_LOCK_SECS=7200
KAEL_MAKER_LOCK_SECS=3600
KAEL_MIN_GAP_SECS=1800
KAEL_CLOSED_TESTNET_MAX_STEPS=120
KAEL_CLOSED_TESTNET_POLL_SECS=1

# Required only when intentionally broadcasting against closed/local testnet.
# KAEL_CLOSED_TESTNET_SEND_TX=I_UNDERSTAND_THIS_USES_TEST_FUNDS
